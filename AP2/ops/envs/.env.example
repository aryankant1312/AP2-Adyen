# Copy to ops/envs/.env and fill in real values.
#
# ----- MCP gateway -----
# Auth is OFF by default so ChatGPT developer-mode / similar connectors
# (which only offer OAuth/Mixed/No auth, not plain bearer) can connect
# straight away. Flip to MCP_REQUIRE_AUTH=true + set MCP_TOKENS below to
# re-enable the bearer gate.
MCP_REQUIRE_AUTH=false
# Comma-separated bearer tokens — only consulted when MCP_REQUIRE_AUTH=true.
# Generate with `python -c "import secrets; print(secrets.token_urlsafe(32))"`.
MCP_TOKENS=dev-token-change-me

# ----- PSP selection -----
# mock = synthetic OTP=123 (no Adyen needed). adyen = real PSP.
PSP_ADAPTER=mock

# ----- Adyen sandbox -----
# Required only when PSP_ADAPTER=adyen.
ADYEN_API_KEY=
ADYEN_MERCHANT_ACCOUNT=
# Hex-encoded HMAC key from your webhook config.
ADYEN_HMAC_KEY=
ADYEN_ENV=TEST
# Optional override; defaults to https://checkout-test.adyen.com/v71
ADYEN_API_BASE=
# Where Adyen redirects shoppers after the 3DS2 challenge — must be reachable
# from the shopper's browser. In dev, set this to your tunnel URL +
# /webhooks/adyen/3ds-return so the gateway can finalise.
ADYEN_RETURN_URL=https://example.com/ap2-poc/return

# ----- Service URLs (set automatically inside compose; override only for local dev) -----
# MERCHANT_AGENT_URL=http://localhost:8001
# CREDENTIALS_PROVIDER_URL=http://localhost:8002
# MERCHANT_PAYMENT_PROCESSOR_URL=http://localhost:8003

# ----- Data + keys -----
DB_PATH=/app/data/pharmacy.sqlite
SHOPPER_KEY_PATH=/app/keys/shopper_key.pem
MERCHANT_PRIVATE_KEY_PATH=/app/keys/merchant_private.pem
